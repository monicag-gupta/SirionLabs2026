package pkg1;

import srcPkg.MathFns;

interface tests{
	void test();
}

public class Main {
	static {
		System.out.println("Only Once : Before All Tests");
	}
	
	public static void initB4EachTest() {
		System.out.println("Test Begins");
	}
	
	public static void cleanAfterEachTest() {
		System.out.println("Test ends");
	}
	
	public void TestCaseSquare() {
		if(MathFns.square(2) == 4) {
			System.out.println("Test Succedded");
			
		}
		else
			System.err.println("Test Failed");
	}
	public void TestCaseMax() {
		if(MathFns.max(new int[] {0,1,8,4}) == 8) {
			System.out.println("Test Succedded");
			
		}
		else
			System.err.println("Test Failed");
	}
	public void TestCaseMaxNeg() {
		if(MathFns.max(new int[] {-2,-9,-8,-4}) == -2) {
			System.out.println("Test Succedded");
			
		}
		else
			System.err.println("Test Failed");
	}
	
	public static void runTest(tests t) {
		initB4EachTest();
		t.test();
		cleanAfterEachTest();
	}
	public static void AfterAllTests() {
		System.out.println("Cleanup post all tests");
	}
	public static void main(String[] args) {
//		System.out.println("Main called");

		runTest(new Main() :: TestCaseMax);
		runTest(new Main() :: TestCaseSquare);
		runTest(new Main() :: TestCaseMaxNeg);
		
		
		AfterAllTests();

	}

}






The Junit 5.x framework is annotation based, so let's see the annotations that can be used while writing the test cases.
@Test annotation specifies that method is the test method.
@Test(timeout=1000) annotation specifies that method will be failed if it takes longer than 1000 milliseconds (1 second).
@BeforeClass annotation specifies that method will be invoked only once, before starting all the tests.
@Before annotation specifies that method will be invoked before each test.
@After annotation specifies that method will be invoked after each test.
@AfterClass annotation specifies that method will be invoked only once, after finishing all the tests.




The org.junit.Assert class provides methods to assert the program logic.
Methods of Assert class
void assertEquals(boolean expected,boolean actual): checks that two primitives/objects are equal. It is overloaded.
void assertTrue(boolean condition): checks that a condition is true.
void assertFalse(boolean condition): checks that a condition is false.
void assertNull(Object obj): checks that object is null.
void assertNotNull(Object obj): checks that object is not null.







