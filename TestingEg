package srcPkg;

public class MathFns {
	public static int square(int x) {
		return x*x;
	}
	public static int cube(int x) {
		return x*x*x;
	}
	public static int max(int[] nos) {
		int m=0;
		for(int a : nos) {
			if(m<a) {
				m=a;
			}
		}
		return m;
	}

}





