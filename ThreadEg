package pkg2;


public class ThreadEg1 {

	public static void main(String[] args) throws InterruptedException {
		Runnable rth1=()->{
			for(int i=0;i<10;i++) {
				System.out.println(Thread.currentThread().getName() + ": iteration: " + i);
				if(i==5) {
					try {
						Thread.sleep(1000);
					} catch (InterruptedException e) { }
				}
			}
			
		};
		Thread th1=new Thread(rth1, "Th1");
		Thread th2=new Thread(rth1, "Th2");
		th1.start();
		th2.start();
		th1.join();
		System.out.println("Main thread name: "+ Thread.currentThread().getName());

	}

}








package pkg2;

class Account {
	String name;
	int bal;
	public Account(String name, int bal) {this.name=name;this.bal=bal;System.out.println("Name:"+name+" has bal: "+bal);}
	public synchronized void withdraw(int amt) throws InterruptedException {
		if(amt>bal)
			System.out.println("Insufficient bal");
		else
			bal = bal - amt;
		Thread.sleep(300);
		System.out.println(amt + " withdrawn, bal remains "+ bal + " from account: "+ name);
	}
	public synchronized void deposit(int amt) throws InterruptedException {
		bal = bal + amt;
		Thread.sleep(1000);
		System.out.println(amt + " deposited, bal becomes "+ bal+ " from account: "+ name);
	}
}

class WithDrawTh implements Runnable{
	Account ac;
	int amt;
	public WithDrawTh(Account ac, int amt) {this.ac=ac;this.amt=amt;}
	public void run() {
		try {
			ac.withdraw(amt);
		} catch (InterruptedException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	}
}
class DepositTh implements Runnable{
	Account ac;
	int amt;
	public DepositTh(Account ac, int amt) {this.ac=ac;this.amt=amt;}
	public void run() {
		try {
			ac.deposit(amt);
		} catch (InterruptedException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	}
}

public class SyncEg1 {

	public static void main(String[] args) {
		Account a1=new Account("John",1000);
		Account a2=new Account("Jane",10000);
		Account a3=new Account("Bob",5000);
		
		Thread thJohnWith = new Thread(new WithDrawTh(a1,500));
		Thread thJohnDepo = new Thread(new DepositTh(a1,500));
		Thread thJaneWith = new Thread(new WithDrawTh(a2,700));
		Thread thJaneDepo = new Thread(new DepositTh(a2,1000));
		Thread thBobWith = new Thread(new WithDrawTh(a3,5000));
		Thread thBobDepo = new Thread(new DepositTh(a3,300));
		thJohnWith.start();
		thJohnDepo.start();
		thJaneWith.start();
		thJaneDepo.start();
		thBobWith.start();
		thBobDepo.start();
	}

}









package pkg2;

class A extends Thread {
	String s;

	public A(String str) {
		s = str;
	}

	public void run() {
		System.out.println("Thread: " + s + " started");
		for (int i = 1; i <= 4; i++) {
			System.out.println("\t From " + s + " : i= " + i);
		}
		System.out.println("Exit from " + s);
	}
}

public class PriorityEg {
	public static void main(String args[]) {
		A threadA = new A("ThreadA");
		A threadB = new A("ThreadB");
		A threadC = new A("ThreadC");
		System.out.println("Default Priority: " + threadA.getPriority());
		threadC.setPriority(Thread.MAX_PRIORITY);
		threadB.setPriority(threadA.getPriority() + 1);
		threadA.setPriority(Thread.MIN_PRIORITY);
		System.out.println("Started Thread A with Priority " + threadA.getPriority());
		threadA.start();
		System.out.println("Started Thread B with Priority " + threadB.getPriority());
		threadB.start();
		System.out.println("Started Thread C with Priority " + threadC.getPriority());
		threadC.start();
		System.out.println("End of main thread");
	}
}









