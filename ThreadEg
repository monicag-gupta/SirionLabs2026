package pkg2;

class Account {
	String name;
	int bal;
	public Account(String name, int bal) {this.name=name;this.bal=bal;System.out.println("Name:"+name+" has bal: "+bal);}
	public synchronized void withdraw(int amt) throws InterruptedException {
		if(amt>bal)
			System.out.println("Insufficient bal");
		else
			bal = bal - amt;
		Thread.sleep(300);
		System.out.println(amt + " withdrawn, bal remains "+ bal + " from account: "+ name);
	}
	public synchronized void deposit(int amt) throws InterruptedException {
		bal = bal + amt;
		Thread.sleep(1000);
		System.out.println(amt + " deposited, bal becomes "+ bal+ " from account: "+ name);
	}
}

