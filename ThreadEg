package pkg2;

class A extends Thread {
	String s;

	public A(String str) {
		s = str;
	}

	public void run() {
		System.out.println("Thread: " + s + " started");
		for (int i = 1; i <= 4; i++) {
			System.out.println("\t From " + s + " : i= " + i);
		}
		System.out.println("Exit from " + s);
	}
}

public class PriorityEg {
	public static void main(String args[]) {
		A threadA = new A("ThreadA");
		A threadB = new A("ThreadB");
		A threadC = new A("ThreadC");
		System.out.println("Default Priority: " + threadA.getPriority());
		threadC.setPriority(Thread.MAX_PRIORITY);
		threadB.setPriority(threadA.getPriority() + 1);
		threadA.setPriority(Thread.MIN_PRIORITY);
		System.out.println("Started Thread A with Priority " + threadA.getPriority());
		threadA.start();
		System.out.println("Started Thread B with Priority " + threadB.getPriority());
		threadB.start();
		System.out.println("Started Thread C with Priority " + threadC.getPriority());
		threadC.start();
		System.out.println("End of main thread");
	}
}





package pkg2;

class Chat {
	boolean flag = false;

	public synchronized void Question(String msg) {
		if (flag) {
			try {
				wait();
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
		}
		System.out.println(msg);
		flag = true;
		notify();
	}

	public synchronized void Answer(String msg) {
		if (!flag) {
			try {
				wait();
			} catch (InterruptedException e) {
				e.printStackTrace();
			}
		}
		System.out.println(msg);
		flag = false;
		notify();
	}
}

class T1 implements Runnable {
	Chat m;
	String[] s1 = { "Hi", "How are you ?", "I am also doing fine!" };

	public T1(Chat m1) {
		this.m = m1;
		new Thread(this).start();
	}

	public void run() {
		for (int i = 0; i < s1.length; i++) {
			m.Question("Person1: " + s1[i]);
		}
	}
}

class T2 implements Runnable {
	Chat m;
	String[] s2 = { "Hi", "I am good, what about you?", "Great!" };

	public T2(Chat m2) {
		this.m = m2;
		new Thread(this).start();
	}

	public void run() {
		for (int i = 0; i < s2.length; i++) {
			m.Answer("Person2: " + s2[i]);
		}
	}
}

public class TestThread {
	public static void main(String[] args) {
		Chat m = new Chat();
		new T1(m);
		new T2(m);
	}
}





