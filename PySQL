database.py


import os
import mysql.connector
from mysql.connector import Error

def get_connection():
    """Create and return a connection to MySQL."""
    try:
        connection = mysql.connector.connect(
            host=os.getenv("MYSQL_HOST", "localhost"),
            port=int(os.getenv("MYSQL_PORT", "3306")),
            user=os.getenv("MYSQL_USER", "root"),
            password=os.getenv("MYSQL_PASSWORD", "root"),
            database=os.getenv("MYSQL_DATABASE", "training_db")
        )
        return connection
    except Error as error:
        print(f"Database connection failed: {error}")
        return None






test_connection.py


from database import get_connection

def test_connection():
    connection = get_connection()
    if connection is None:
        print("Unable to connect to MySQL.")
        return
    try:
        print("Connected to MySQL successfully.")
        cursor = connection.cursor()
        cursor.execute("SELECT DATABASE()")
        database_name = cursor.fetchone()[0]
        print(f"Selected database: {database_name}")
    finally:
        if "cursor" in locals():
            cursor.close()
        connection.close()
        print("MySQL connection closed.")

if __name__ == "__main__":
    test_connection()






create_database.py


import os
import mysql.connector
from mysql.connector import Error


def create_database_and_table():
    connection = None
    cursor = None
    try:
        connection = mysql.connector.connect(
            host=os.getenv("MYSQL_HOST", "localhost"),
            port=int(os.getenv("MYSQL_PORT", "3306")),
            user=os.getenv("MYSQL_USER", "root"),
            password=os.getenv("MYSQL_PASSWORD", "root")
        )
        cursor = connection.cursor()
        cursor.execute("CREATE DATABASE IF NOT EXISTS training_db")
        cursor.execute("USE training_db")
        create_table_query = """
            CREATE TABLE IF NOT EXISTS courses (
                course_id INT PRIMARY KEY AUTO_INCREMENT,
                course_name VARCHAR(150) NOT NULL,
                category VARCHAR(100) NOT NULL,
                duration_hours DECIMAL(6, 2) NOT NULL,
                trainer VARCHAR(100) NOT NULL,
                fee DECIMAL(10, 2) NOT NULL,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        """
        cursor.execute(create_table_query)
        print("Database and table created successfully.")
    except Error as error:
        print(f"Database setup failed: {error}")
    finally:
        if cursor is not None:
            cursor.close()
        if connection is not None:
            connection.close()

if __name__ == "__main__":
    create_database_and_table()




