//Java 21 allows multiple labels and block statements within a switch expression:
package pkg1;
import java.util.Scanner;
public class Hi {
	public static void main(String[] args) {
		System.out.print("Enter Week day's number: ");
		int day;
		day = (new Scanner(System.in)).nextInt();
		String dayType = switch (day) {
		    case 1, 2, 3, 4, 5 -> "Weekday";
		    case 6, 7 -> "Weekend";
		    default -> {
		        yield "Invalid day"; 
		        //The yield keyword is used to return a value from 
		        // the case block in a switch expression.
		        //It allows you to use block statements (enclosed in curly braces) 
		        // and provide a value to be returned from the switch expression.
		    }
		};
		System.out.println(dayType); // Output: Weekday for day 3
		
		
		System.out.println("\n\nPart 2\n");
		System.out.print("Enter Week day's name in full: ");
		enum Day {
		    MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY
		}
		Day day2 = Day.valueOf((new Scanner(System.in)).nextLine().toUpperCase());
		String dayType2 = switch (day2) {
		    case MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY -> "Weekday";
		    case SATURDAY, SUNDAY -> "Weekend";
		    //default ->{yield "NoDay";}
		};
		System.out.println(dayType2); // Output: Weekday for Monday

	}
}






package pkg1;

class Empl<T>{
	T empId;
	String empName;
	public Empl(T empId, String empName) {
		this.empId = empId;
		this.empName = empName;
	}
	public Empl() {}
	public T getEmpId() {
		return empId;
	}
	public void setEmpId(T empId) {
		this.empId = empId;
	}
	public String getEmpName() {
		return empName;
	}
	public void setEmpName(String empName) {
		this.empName = empName;
	}
	@Override
	public String toString() {
		return "Empl [empId=" + empId + ", empName=" + empName + "]";
	}
	
	
}


public class GenericEg {

	public static void main(String[] args) {
		Empl<Integer> emp1=new Empl<>(101,"John");
		System.out.println("Empl1<int> : " + emp1);
		Empl<String> emp2=new Empl<>("E101","John");
		System.out.println("Empl1<String> : " + emp2);
	}

}






