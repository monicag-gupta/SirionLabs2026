StudentProperties.java

package com.springboot.model;

import org.springframework.boot.context.properties.ConfigurationProperties;
import org.springframework.stereotype.Component;

@Component
@ConfigurationProperties(prefix="student")
public class StudentProperties {
    private String name;
    private String course;
    private int age;
	public String getName() {return name; }
	public void setName(String name) { this.name = name; }
	public String getCourse() { return course; 	}
	public void setCourse(String course) { this.course = course; }
	public int getAge() { return age;	}
	public void setAge(int age) { this.age = age; }
}






Spring automatically performs
StudentProperties student = new StudentProperties();
student.setName("Rahul Sharma");
student.setCourse("Java Full Stack");
student.setAge(22);
You never write this code.




StudentController.java


package com.springboot.controller;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

import com.springboot.model.StudentProperties;
@RestController
public class StudentController {
	@Autowired
	StudentProperties std;
	
    @Value("${college.name}")
    private String collegeName;

    @Value("${college.city}")
    private String city;

    @Value("${college.established}")
    private int year;

    @GetMapping("/college")
    public String collegeInfo() {
        return "College : " + collegeName + "<br>City : "
                + city  + "<br>Established : " + year;
    }
    @GetMapping("/student")
    public StudentProperties studentInfo() {
        return std;
    }
}






Understanding @Value
Spring reads
college.name=ABC Engineering College
and injects it into
@Value("${college.name}")private String collegeName;





